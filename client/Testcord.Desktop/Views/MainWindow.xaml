<Window x:Class="Testcord.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Testcord.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Testcord"
        Width="1440"
        Height="860"
        MinWidth="1100"
        MinHeight="680"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84" />
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0F1115"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="12">
                <TextBlock Margin="0,12,0,16"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Text="SERVERS" />

                <ItemsControl ItemsSource="{Binding Servers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:ServerItemViewModel}">
                            <Border Width="52"
                                    Height="52"
                                    Margin="0,0,0,12"
                                    CornerRadius="18">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Text="{Binding Glyph}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1"
              Background="{StaticResource PanelBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="74" />
                <RowDefinition Height="*" />
                <RowDefinition Height="88" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
                <StackPanel Margin="20,18,20,18">
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentWorkspace}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Text="Modular workspace ready for Auth, Friends, Messaging and Voice." />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="14,18,14,18">
                <TextBlock Margin="10,0,0,12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           Text="TEXT CHANNELS" />
                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:ChannelItemViewModel}">
                            <Border Margin="0,0,0,8"
                                    Padding="12,10"
                                    CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="14"
                                               Text="{Binding Prefix}" />
                                    <TextBlock Margin="8,0,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"
                                               Text="{Binding Name}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="16"
                    Padding="14"
                    Background="{StaticResource PanelAltBackgroundBrush}"
                    CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Width="40"
                            Height="40"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="20">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#0B1017"
                                   FontWeight="Bold"
                                   Text="TC" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="testcord_dev" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Text="Online" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="74" />
                <RowDefinition Height="*" />
                <RowDefinition Height="96" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelAltBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentChannel}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Text="Foundational discussion room for solution setup, persistence and platform contracts." />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Margin="0,0,12,0"
                                Padding="12,8"
                                Background="{StaticResource AccentMutedBrush}"
                                CornerRadius="12">
                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="SignalR Ready" />
                        </Border>
                        <Border Padding="12,8"
                                Background="#28313B"
                                CornerRadius="12">
                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Voice MVP Planned" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl Margin="24,18,24,18"
                              ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:MessageItemViewModel}">
                            <Border Margin="0,0,0,12"
                                    Padding="16"
                                    Background="{StaticResource PanelBackgroundBrush}"
                                    CornerRadius="16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Author}" />
                                        <TextBlock Margin="10,1,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"
                                                   Text="{Binding Time}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               Text="{Binding Content}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Margin="24,8,24,24"
                    Padding="18,16"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Text="Message #foundation" />
                    <TextBox Grid.Row="1"
                             Margin="0,10,0,0"
                             Padding="14,12"
                             Background="{StaticResource PanelAltBackgroundBrush}"
                             BorderBrush="{StaticResource BorderBrushDark}"
                             BorderThickness="1"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="14"
                             Text="{Binding DraftMessage, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
